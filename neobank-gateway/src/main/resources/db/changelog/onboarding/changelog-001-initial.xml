<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.35.xsd">

    <!-- Onboarding Module: Initial Schema -->
    <changeSet id="onboarding-001" author="neobank">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="onboarding_profiles" schemaName="schema_onboarding"/>
            </not>
        </preConditions>
        
        <createTable tableName="onboarding_profiles" schemaName="schema_onboarding">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="status" type="VARCHAR(50)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="kyc_verified" type="BOOLEAN" defaultValue="false">
                <constraints nullable="false"/>
            </column>
            <column name="kyc_verified_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="approved_by" type="UUID"/>
            <column name="approved_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <createIndex tableName="onboarding_profiles" schemaName="schema_onboarding" indexName="idx_onboarding_user_id">
            <column name="user_id"/>
        </createIndex>
        
        <createIndex tableName="onboarding_profiles" schemaName="schema_onboarding" indexName="idx_onboarding_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
