<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.35.xsd">

    <!-- Core Banking Module: Transfers Schema -->
    <changeSet id="core-002" author="neobank">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="transfers" schemaName="schema_core"/>
            </not>
        </preConditions>
        
        <createTable tableName="transfers" schemaName="schema_core">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="from_account_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_transfers_from_account" references="schema_core.accounts(id)"/>
            </column>
            <column name="to_account_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_transfers_to_account" references="schema_core.accounts(id)"/>
            </column>
            <column name="amount" type="DECIMAL(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="CHAR(3)" defaultValue="USD">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="failure_reason" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="completed_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="idempotency_key" type="VARCHAR(255)">
                <constraints unique="true"/>
            </column>
        </createTable>
        
        <createIndex tableName="transfers" schemaName="schema_core" indexName="idx_transfers_from_account">
            <column name="from_account_id"/>
        </createIndex>
        
        <createIndex tableName="transfers" schemaName="schema_core" indexName="idx_transfers_to_account">
            <column name="to_account_id"/>
        </createIndex>
        
        <createIndex tableName="transfers" schemaName="schema_core" indexName="idx_transfers_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
