<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.35.xsd">

    <!-- Core Banking Module: Branches Schema -->
    <changeSet id="core-003" author="neobank">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="branches" schemaName="schema_core"/>
            </not>
        </preConditions>
        
        <createTable tableName="branches" schemaName="schema_core">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="address" type="TEXT"/>
            <column name="city" type="VARCHAR(100)"/>
            <column name="state" type="VARCHAR(100)"/>
            <column name="zip_code" type="VARCHAR(20)"/>
            <column name="phone" type="VARCHAR(50)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="manager_id" type="UUID"/>
            <column name="status" type="VARCHAR(50)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <createIndex tableName="branches" schemaName="schema_core" indexName="idx_branches_code">
            <column name="code"/>
        </createIndex>
        
        <createIndex tableName="branches" schemaName="schema_core" indexName="idx_branches_city">
            <column name="city"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
