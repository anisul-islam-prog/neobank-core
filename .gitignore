# =============================================================================
# NeoBank Core — .gitignore
# =============================================================================

# ── Maven ────────────────────────────────────────────────────────────────────
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.properties

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
.classpath
.project
.settings/
bin/
.metadata
*.tmproj
*.sw*

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Testing ──────────────────────────────────────────────────────────────────
*.dump
surefire-reports/
test-results/

# ── Local configuration ─────────────────────────────────────────────────────
local.properties
config.properties

# ── Environment specific ─────────────────────────────────────────────────────
.env
.env.local
.env.dev
.env.prod
.env.testing
.env.staging
.env.production
.env.example

# ── Java ─────────────────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.tar.bz2

# ── Temporary files ──────────────────────────────────────────────────────────
*~
.#*
*#
*.bak
*.old
*.tmp
*.swp
*-backup

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Claude Code ──────────────────────────────────────────────────────────────
.claude/

# ── Qwen Code ────────────────────────────────────────────────────────────────
.qwen/

# ── Frontend build artifacts and generated files ─────────────────────────────
apps/*/package-lock.json
apps/*/src/test/
apps/*/vitest.config.ts
apps/*/src/components/
apps/*/src/app/dashboard/

# ── Runtime artifacts ────────────────────────────────────────────────────────
# PID files created by run-all.sh during local development
*.pid

# ── OTel & Observability local data ─────────────────────────────────────────
# Local OTel collector data, traces, and spans captured during dev
otel-data/
traces/
spans/

# ── Testcontainers ───────────────────────────────────────────────────────────
# Testcontainers Ryuk and local container artifacts
~/.testcontainers/
.ryuk*

# ── Docker ───────────────────────────────────────────────────────────────────
# Docker compose override files for local customization
docker-compose.override.yml
